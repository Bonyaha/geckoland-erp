{
	"watch": [
		"src/**/*"
	],
	"ignore": [
		"src/storage/gmail-history.json",
		"src/config/credentials/gmail-token.json",
		"src/storage/rozetkaTokenCache.json",
		"node_modules/**/*",
		"dist/**/*",
		"logs/**/*",
		".cron-initialized"
	],
	"ext": "ts,js,json",
	"exec": "node --loader ts-node/esm src/index.ts"
}