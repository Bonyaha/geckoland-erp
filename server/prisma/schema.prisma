generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Users {
  userId   String @id @default(cuid())
  name     String
  email    String @unique
  password String
  role     String @default("user")
}

model Clients {
  clientId      String   @id @default(cuid())
  firstName     String
  lastName      String
  secondName    String?
  phone         String   @unique
  email         String?
  address       String?
  deliveryOptionName  DeliveryOption? // Nova Poshta, UkrPoshta, etc.
  paymentOptionName   PaymentOption?
  reliability   String? 
  totalOrders   Int      @default(0)
  totalSpent    Decimal  @default(0) @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)
  orders        Orders[]
}

model Products {
  productId        String       @id
  sku              String?
  name             String
  price            Decimal      @db.Decimal(10, 2)
  stockQuantity    Int
  source           Source       @default(prom)
  externalIds      Json
  description      String?
  mainImage        String?
  images           String[]
  available        Boolean
  priceOld         Decimal?     @db.Decimal(10, 2)
  pricePromo       Decimal?     @db.Decimal(10, 2)
  updatedPrice     Decimal?     @db.Decimal(10, 2)
  currency         String?
  dateModified     DateTime?    @db.Timestamptz(6)
  lastSynced       DateTime?    @db.Timestamptz(6)
  needsSync        Boolean      @default(false)
  categoryData     Json?
  measureUnit      String?
  lastPromSync     DateTime?    @db.Timestamptz(6)
  lastRozetkaSync  DateTime?    @db.Timestamptz(6)
  needsPromSync    Boolean      @default(false)
  needsRozetkaSync Boolean      @default(false)
  promQuantity     Int?
  rozetkaQuantity  Int?
  costPrice        Decimal?     @db.Decimal(10, 2)
  OrderItems       OrderItems[]
  Purchases        Purchases[]
  Sales            Sales[]
}

model Orders {
  orderId                 String       @id
  externalOrderId         String
  source                  Source
  orderNumber             String?
  createdAt               DateTime     @db.Timestamptz(6)
  updatedAt               DateTime     @updatedAt @db.Timestamptz(6)
  lastModified            DateTime?    @db.Timestamptz(6)
  clientId                String?
  clientFirstName         String
  clientLastName          String
  clientSecondName        String?
  clientPhone             String
  clientEmail             String?
  clientFullName          String?
  recipientFirstName      String?
  recipientLastName       String?
  recipientSecondName     String?
  recipientPhone          String?
  recipientFullName       String?
  deliveryOptionName      DeliveryOption?
  deliveryAddress         String?
  deliveryCity            String?
  trackingNumber          String?
  deliveryCost            Decimal?     @db.Decimal(10, 2)
  deliveryProviderData    Json?  
  paymentOptionName       PaymentOption?
  paymentData             Json?
  paymentStatus           String?
  totalAmount             Decimal      @db.Decimal(10, 2)
  totalAmountWithDiscount Decimal?     @db.Decimal(10, 2)
  fullPrice               Decimal?     @db.Decimal(10, 2)
  currency                String       @default("UAH")
  totalQuantity           Int?
  itemCount               Int
  status                  OrderStatus  @default(RECEIVED)
  statusName              String?  
  cpaCommission           Decimal?     @db.Decimal(10, 2)
  prosaleCommission       Decimal?     @db.Decimal(10, 2)
  isCommissionRefunded    Boolean      @default(false)
  clientNotes             String?
  sellerComment           String?  
  orderSource             String?
  dontCallCustomer        Boolean      @default(false)
  isViewed                Boolean      @default(false)  
  rawOrderData            Json?
  orderItems              OrderItems[]
  client                  Clients?     @relation(fields: [clientId], references: [clientId])
  sales                   Sales[]
}

model OrderItems {
  orderItemId          String    @id @default(cuid())
  orderId              String
  productId            String
  sku                  String?
  productName          String
  productNameMultilang Json?
  productImage         String?
  productUrl           String?
  quantity             Int
  unitPrice            Decimal   @db.Decimal(10, 2)
  totalPrice           Decimal   @db.Decimal(10, 2)
  measureUnit          String?
  cpaCommission        Decimal?  @db.Decimal(10, 2)
  rawItemData          Json?
  order                Orders    @relation(fields: [orderId], references: [orderId], onDelete: Cascade)
  product              Products? @relation(fields: [productId], references: [productId])
  sales                Sales[]

  @@unique([orderId, productId])
  @@index([sku])
}

model Sales {
  saleId      String      @id @default(cuid())
  productId   String
  orderId     String?
  orderItemId String?
  createdAt   DateTime    @db.Timestamptz(6)
  quantity    Int
  unitPrice   Decimal     @db.Decimal(10, 2)
  totalAmount Decimal     @db.Decimal(10, 2)
  sku         String?
  name        String?
  source      Source?
  orderNumber String?
  product     Products    @relation(fields: [productId], references: [productId])
  order       Orders?     @relation(fields: [orderId], references: [orderId])
  orderItem   OrderItems? @relation(fields: [orderItemId], references: [orderItemId])

  @@index([createdAt])
  @@index([productId])
  @@index([orderId])
}

model Purchases {
  purchaseId String   @id
  productId  String
  timestamp  DateTime
  quantity   Int
  unitCost   Decimal  @db.Decimal(10, 2)
  totalCost  Decimal  @db.Decimal(10, 2)
  product    Products @relation(fields: [productId], references: [productId])
}

model Expenses {
  expenseId String   @id
  category  String
  amount    Decimal  @db.Decimal(10, 2)
  timestamp DateTime
}

model SalesSummary {
  salesSummaryId   String   @id
  totalValue       Decimal  @db.Decimal(10, 2)
  changePercentage Float?
  date             DateTime
}

model PurchaseSummary {
  purchaseSummaryId String   @id
  totalPurchased    Decimal  @db.Decimal(10, 2)
  changePercentage  Float?
  date              DateTime
}

model ExpenseSummary {
  expenseSummaryId  String              @id
  totalExpenses     Decimal             @db.Decimal(10, 2)
  date              DateTime
  ExpenseByCategory ExpenseByCategory[]
}

model ExpenseByCategory {
  expenseByCategoryId String         @id
  expenseSummaryId    String
  category            String
  amount              Decimal        @db.Decimal(10, 2)
  date                DateTime
  expenseSummary      ExpenseSummary @relation(fields: [expenseSummaryId], references: [expenseSummaryId])
}

enum Source {
  prom
  rozetka
  crm
}

enum OrderStatus {
  RECEIVED
  PREPARED
  SHIPPED
  AWAITING_PICKUP
  DELIVERED
  CANCELED
  RETURN
}

enum DeliveryOption {
  NovaPoshta
  UkrPoshta
}

enum PaymentOption {
  ApplePay
  GooglePay
  RozetkaPay
  IBAN
  PromPayment
  CashOnDelivery
}